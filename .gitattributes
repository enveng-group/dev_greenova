# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text diff=python
*.pyi text diff=python
*.pth text
*.ipynb text
MANIFEST.in text
setup.cfg text
setup.py text
pyproject.toml text
requirements*.txt text

# Docker files
.dockerignore text
docker-compose*.yml text
Dockerfile text

# Scripts
*.sh text eol=lf
Makefile text

# Database files
*.pkl binary
*.db binary
*.sqlite3 binary

# Web files
*.json text
*.js text diff=javascript
*.css text diff=css
*.htm text diff=html
*.html text diff=html

# Documentation
*.md text diff=markdown
*.rst text
LICENSE text

# Graphics
*.svg text
*.ico binary
*.gif binary
*.jpg binary
*.png binary
*.pdf binary

# Config files
*.conf text
*.cfg text
*.ini text
*.toml text
*.yaml text
*.yml text

# Git config files
*secret* filter=git-crypt diff=git-crypt
*.key filter=git-crypt diff=git-crypt
.env* filter=git-crypt diff=git-crypt
.snyk filter=git-crypt diff=git-crypt