{
    "name": "dev_Greenova",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "workspaceFolder": "/workspaces/dev_greenova",
    "workspaceMount": "source=/Users/adriangallo/devcontainer,target=/workspaces/dev_greenova,type=bind,consistency=cached",
    "features": {},
    "customizations": {
        "vscode": {
            "settings": {
                "github.copilot.chat.codeGeneration.useInstructionFiles": true,
                "files.autoSave": "afterDelay",
                "files.autoSaveDelay": 1000,
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                },
                "python.envFile": "/workspaces/dev_greenova/.env",
                "python.interpreter.infoVisibility": "always",
                "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
                "python.terminal.activateEnvironment": true
            },
            "extensions": [
                "ms-python.python",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "batisteo.vscode-django",
                "EditorConfig.EditorConfig",
                "dotenv.dotenv-vscode",
                "dotenv.dotenvx-vscode",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "mounts": [
        "source=/Users/adriangallo/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
        "source=/Users/adriangallo/.gnupg,target=/home/vscode/.gnupg,type=bind,readonly",
        "source=dev_greenova_data,target=/mnt/data,type=volume"
    ],
    //"remoteEnv": {
        //"DOTENV_KEY": "${localEnv:DOTENV_KEY}"
    //},
    "forwardPorts": [8000, 8080],
    "postCreateCommand": "./.devcontainer/post-create.sh",
    "remoteUser": "vscode"
}
