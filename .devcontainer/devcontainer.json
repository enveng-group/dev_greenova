{
  "name": "Greenova Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "initializeCommand": "make initialize",
  "onCreateCommand": "make create",
  "postCreateCommand": "make post-create",
  "postStartCommand": "make post-start",
  "postAttachCommand": "make attach",
  "updateContentCommand": "make update",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.makefile-tools"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.devcontainer/scripts,target=/workspaces/scripts,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "MAKE_PATH": "/usr/bin/make",
    "SCRIPTS_DIR": "/workspaces/scripts"
  }
}