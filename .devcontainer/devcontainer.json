// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/alpine
{
	"name": "dev_Greenova",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:alpine",
	//"features": {}
	"customizations": {
		"vscode": {
			"settings": {
				"github.copilot.chat.codeGeneration.useInstructionFiles": true,
				"files.autoSave": "afterDelay",
				"files.autoSaveDelay": 1000
			},
			"extensions": [
				"ms-python.python",
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"batisteo.vscode-django"
			]
		}
	},
	"postCreateCommand": "python3 -m venv /workspaces/dev_greenova/.venv && . /workspaces/dev_greenova/.venv/bin/activate && python -m pip install --upgrade pip && pip install -r requirements.txt",
	"postStartCommand": ". /workspaces/dev_greenova/.venv/bin/activate && set -a && . /workspaces/dev_greenova/.env && set +a"
}
