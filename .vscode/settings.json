{
  // Core Python/Django Settings
  "python.defaultInterpreterPath": "/home/ubuntu/.local/share/uv/python/cpython-3.13.1-linux-aarch64-gnu/bin/python3.13",
  "python.envFile": "/.env",
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.exclude": [
    "**/__pycache__",
    "**/migrations",
    "**/.venv",
    "**/staticfiles",
    "**/node_modules",
    "**/static",
    "**/media"
  ],
  "python.analysis.aiCodeActions": {
    "enabled": true
  },
  "python.analysis.autoSearchPaths": true,
  "python.activeStateToolPath": "state",
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoIndent": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.enablePytestSupport": true,
  "python.analysis.indexing": true,
  "python.analysis.languageServerMode": "full",
  "python.languageServer": "Pylance",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.shellIntegration.enabled": true,
  "python.testing.pytestEnabled": true,
  "isort.check": true,
  // Django-specific settings
  "files.associations": {
    "**/*.html": "html",
    "**/templates/**/*.html": "django-html",
    "**/templates/*.html": "django-html",
    "**/templates/*/*.html": "django-html",
    "**/requirements{/**,*}.{txt,in}": "pyproject.toml",
    "*.toml": "toml",
    ".env*": "dotenv",
    "*.sql": "sql",
    "*.nu": "nu",
    ".nu-env": "nu",
    ".nu-config": "nu"
  },
  "django.snippets.use": true,
  // Editor Core Settings
  "editor.formatOnSave": true,
  "editor.rulers": [
    79,
    88,
    100
  ],
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always"
  },
  // Code Formatting
  "black-formatter.cwd": "/home/ubuntu/greenova",
  "black-formatter.importStrategy": "fromEnvironment",
  "black-formatter.args": [
    "--line-length",
    "79",
  ],
  "isort.importStrategy": "fromEnvironment",
  // GitHub Copilot
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.advanced": {
    "language.python.suffixPercent": 75,
    "language.django-html.enable": true,
    "language.python.enable": true,
    "language.javascript.enable": true
  },
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".copilot-commit-message-instructions.md"
    }
  ],
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": ".copilot-instructions.md"
    }
  ],
  "github.copilot.chat.copilotDebugCommand.enabled": true,
  "github.copilot.chat.fixTestFailure.enabled": true,
  "github.copilot.chat.followUps": "always",
  "github.copilot.chat.reviewSelection.enabled": true,
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "file": ".copilot-instructions.md"
    }
  ],
  // Environment Integration
  "terminal.integrated.env.linux": {
    "PYTHONPATH": "/home/ubuntu/greenova:/home/ubuntu/greenova/greenova",
    "DJANGO_SETTINGS_MODULE": "greenova.settings",
    "DJANGO_DEBUG": "True",
    "SSH_AUTH_SOCK": "/run/user/1000/keyring/ssh"
  },
  // Performance Optimizations
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/migrations/**": true,
    "**/staticfiles/**": true,
    "**/media/**": true
  },
  // Language Specific
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "[markdown]": {
    "editor.defaultFormatter": "vscode.markdown-language-features",
    "editor.formatOnSave": true
  },
  // Editor Settings
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 500,
  // Git Settings
  "git.ignoreLimitWarning": true,
  "remote.autoForwardPorts": true,
  "git.terminalGitEditor": true,
  // Snyk
  // Terminal
  "terminal.integrated.cwd": "/home/ubuntu/greenova",
  "terminal.integrated.environmentChangesIndicator": "on",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
  // Python Testing
  "python.testing.pytestPath": "/home/ubuntu/greenova/.venv/bin/pytest",
  "python.testing.pytestArgs": [
    "/home/ubuntu/greenova/greenova/tests",
    "-v",
    "--tb=short"
  ],
  "python.testing.unittestEnabled": false,
  // Git Configuration
  "git.enableCommitSigning": true,
  "git.alwaysSignOff": true,
  "git.fetchOnPull": true,
  "git.autofetch": true,
  "git.pruneOnFetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.postCommitCommand": "sync",
  "git.useEditorAsCommitInput": true,
  "git.enabled": true,
  "git.showProgress": true,
  "github.gitProtocol": "ssh"
}
