# Cloudflare
CF_API_TOKEN=""

# Project Environment
PROJECT_DIR=""
PROJECT_NAME=""
ENV_FILE=""
EDITOR="code"
SHELL="/bin/bash"

# Python Environment
PYTHON=""
PYTHON_INTERPRETER=""
PYTHONUNBUFFERED="1"
PYTHONDONTWRITEBYTECODE="1"
PYTHONBREAKPOINT="ipdb.set_trace"
VIRTUAL_ENV_DISABLE_PROMPT="1"

# Django Settings
DJANGO_SETTINGS_MODULE=""
DJANGO_SECRET_KEY=""

# System Paths
PATH="${VIRTUAL_ENV}/bin:${PATH}"
LD_LIBRARY_PATH="/usr/local/lib:/usr/lib"
PKG_CONFIG_PATH="/usr/local/lib/pkgconfig"
MANPATH="/usr/local/man:/usr/local/share/man:/usr/share/man"

# User Environment
USER="vscode"
USERNAME="vscode"
HOME="/home/vscode"
SHELL="/bin/bash"
TERM="xterm-256color"
COLORTERM="truecolor"
TERMINFO="/usr/share/terminfo"

# Display Settings
DISPLAY=":0"
WAYLAND_DISPLAY="wayland-0"
XDG_SESSION_TYPE="wayland"
XDG_RUNTIME_DIR="/run/user/1000"
XDG_DATA_DIRS="/usr/local/share:/usr/share"
XDG_CONFIG_HOME="${HOME}/.config"
XDG_CACHE_HOME="${HOME}/.cache"
XDG_DATA_HOME="${HOME}/.local/share"

# Locale Settings
TZ="Australia/Perth"
LANG="en_AU.UTF-8"
LANGUAGE="en_AU:en"
CHARSET="UTF-8"

# Cloudflare
CF_API_TOKEN=""

# Development Environment
GIT_AUTHOR_NAME=""
GIT_AUTHOR_EMAIL=""
GIT_COMMITTER_NAME=""
GIT_COMMITTER_EMAIL=""
GITHUB_TOKEN=""
GITHUB_USERNAME=""
GITHUB_API_URL="https://api.github.com"

# VS Code Settings
VSCODE_GIT_ENABLED="true"
VSCODE_DEBUGGING_ENABLED="true"
VSCODE_SUGGEST=1

# CI/CD Environment
CI_ENABLED="true"
CI_DEBUG="false"
CI_COMMIT_SHA=""
CI_COMMIT_REF_NAME="main"
CI_PROJECT_NAME="greenova"
CI_REGISTRY=""
CI_REGISTRY_USER=""
CI_REGISTRY_PASSWORD=""

# Docker Environment
DOCKER_BUILDKIT="1"
DOCKER_HOST="unix:///var/run/docker.sock"
DOCKER_REGISTRY=""
DOCKER_USERNAME=""
DOCKER_PASSWORD=""
COMPOSE_PROJECT_NAME="greenova"
COMPOSE_FILE="docker-compose.yml"

# Development Tools
NODE_ENV="development"
NPM_TOKEN=""
POETRY_VIRTUALENVS_CREATE="true"
POETRY_VIRTUALENVS_IN_PROJECT="true"

# Python Environment
PYTHONPATH="/workspaces/dev_greenova"
PYTHONUNBUFFERED="1"
PYTHONDONTWRITEBYTECODE="1"
PYTHONBREAKPOINT="0"
VIRTUAL_ENV="/workspaces/dev_greenova/.venv"
VIRTUAL_ENV_DISABLE_PROMPT="1"


# Django Settings
DJANGO_SETTINGS_MODULE="greenova.settings"
DJANGO_SECRET_KEY=""
DJANGO_DEBUG="True"
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1,0.0.0.0"
DJANGO_INTERNAL_IPS="127.0.0.1"
DJANGO_TIME_ZONE="Australia/Perth"
DJANGO_LANGUAGE_CODE="en-au"

# Django Security Settings
DJANGO_SECURE_SSL_REDIRECT="False"
DJANGO_SESSION_COOKIE_SECURE="False"
DJANGO_CSRF_COOKIE_SECURE="False"

# Django Database Settings
DATABASE_URL="sqlite:///db.sqlite3"

# Django Email Settings
EMAIL_BACKEND="django.core.mail.backends.console.EmailBackend"
EMAIL_HOST="localhost"
EMAIL_PORT="1025"
DEFAULT_FROM_EMAIL="webmaster@localhost"

# Django Media & Static Settings
DJANGO_STATIC_ROOT="/workspaces/dev_greenova/staticfiles"
DJANGO_STATIC_URL="/static/"
DJANGO_MEDIA_ROOT="/workspaces/dev_greenova/media"
DJANGO_MEDIA_URL="/media/"

# Django Logging Settings
DJANGO_LOG_LEVEL="DEBUG"
DJANGO_LOG_FILE="/workspaces/dev_greenova/logs/django.log"

# Greenova Project Settings
GREENOVA_VERSION="1.0.0"
GREENOVA_ENVIRONMENT="development"
GREENOVA_INSTANCE="local"
GREENOVA_API_VERSION="v1"

# Obligation Management Settings
OBLIGATION_AUTO_REMINDER_DAYS="14"
OBLIGATION_CRITICAL_THRESHOLD_DAYS="7"
OBLIGATION_FILE_UPLOAD_MAX_SIZE="10485760"
OBLIGATION_ALLOWED_FILE_TYPES=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg"

# Development Extensions
DEV_AUTO_RELOAD="True"
DEV_DEBUG_TOOLBAR="True"
DEV_SQL_PRINT="True"
DEV_TEST_DATA_SIZE="100"
