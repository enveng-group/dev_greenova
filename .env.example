# Django Core Settings
DJANGO_SECRET_KEY=replace_with_secure_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,app.enssol.com.au,enssol.com.au

# Database Configuration
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Static Files
STATIC_URL=/static/
MEDIA_URL=/media/

# Security Settings
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://app.enssol.com.au,http://enssol.com.au

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Authentication Settings
SITE_ID=1
ACCOUNT_EMAIL_VERIFICATION=mandatory
ACCOUNT_EMAIL_REQUIRED=True

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_SECRET=your-client-secret
