root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
max_line_length = 79
indent_size = 4
# Python-specific settings
known_first_party = greenova
multi_line_output = 3
include_trailing_comma = true
force_grid_wrap = 0
combine_as_imports = true

[*.{html,xml,xhtml}]
indent_size = 2
max_line_length = 120

[*.{yml,yaml,json}]
indent_size = 2
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{js,jsx,ts,tsx,css,scss,less}]
indent_size = 2
max_line_length = 100

[*.{sql,sqlite3}]
indent_size = 2
max_line_length = 120

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
shell_variant = bash
binary_next_line = true
switch_case_indent = true
space_redirects = true

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.env]
insert_final_newline = false

