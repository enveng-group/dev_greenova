#!/usr/bin/env python3
"""Python startup file for Greenova development environment.

This script is executed when the Python interactive interpreter starts.
It provides useful imports and utilities for development sessions.
"""
import os
import sys

# Rest of your imports
import json
import datetime
import logging
from pathlib import Path

# Set up basic logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(),
        logging.FileHandler('logs/greenova-shell.log')
    ]
)
logger = logging.getLogger('greenova-shell')

# Django setup
import django
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'greenova.settings')
try:
    django.setup()
    logger.info("Django environment initialized successfully")
except Exception as e:
    logger.error(f"Failed to initialize Django environment: {e}")
    sys.exit(1)

# Clean up namespace
del Path, logging, json, datetime
quit()
