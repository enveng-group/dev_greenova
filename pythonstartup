#!/usr/bin/env python3
"""Python startup file for Greenova development environment.

This script is executed when the Python interactive interpreter starts.
It provides useful imports and utilities for development sessions.
"""
import os
import sys
import json
import datetime
import logging
from pathlib import Path

# Set up basic logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.StreamHandler(),
        logging.FileHandler('greenova-shell.log')
    ]
)
logger = logging.getLogger('greenova-shell')

# Django setup
import django
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'greenova.settings')
try:
    django.setup()
    logger.info("Django environment initialized successfully")
except Exception as e:
    logger.error(f"Failed to initialize Django environment: {e}")
    sys.exit(1)

# Common Django imports
from django.conf import settings
from django.contrib.auth import get_user_model
from django.core.management import call_command
from django.db import connection
from django.urls import reverse
from django.utils import timezone

# Project-specific imports
from obligations.models import Obligation 
from users.models import User
from audit.models import AuditLog

# Development utilities
def reset_db():
    """Reset database to a clean state."""
    try:
        call_command('flush', interactive=False)
        call_command('migrate')
        logger.info("Database reset complete")
    except Exception as e:
        logger.error(f"Database reset failed: {e}")

def create_test_data(size=None):
    """Create sample data for development."""
    try:
        size = size or os.environ.get('DEV_TEST_DATA_SIZE', 100)
        call_command('create_test_data', size=size)
        logger.info(f"Created {size} test records")
    except Exception as e:
        logger.error(f"Test data creation failed: {e}")

def show_urls():
    """Display all registered URLs."""
    call_command('show_urls')

def shell_plus():
    """Enable Django extensions shell_plus if available."""
    try:
        from django_extensions.management.commands.shell_plus import Command
        Command().handle(interface='ipython')
    except ImportError:
        logger.warning("django-extensions not installed")

# Database utilities
def show_queries():
    """Show SQL queries from the last request."""
    from django.db import connection
    for query in connection.queries:
        print(f"\nTime: {query['time']}")
        print(f"SQL: {query['sql']}\n")

# Environment setup
WORKSPACE_ROOT = Path('/workspaces/dev_greenova')
PROJECT_ROOT = WORKSPACE_ROOT / 'greenova'

# Shell customization
sys.ps1 = '\033[92mGreenova>\033[0m '
sys.ps2 = '\033[94m...>\033[0m '

# Welcome message
print(f"""
\033[92mGreenova Development Shell\033[0m
Python {sys.version.split()[0]}
Django {django.get_version()}
Settings: {os.environ.get('DJANGO_SETTINGS_MODULE')}
Database: {settings.DATABASES['default']['ENGINE'].split('.')[-1]}

Available utilities:
- reset_db() - Reset database to clean state
- create_test_data([size]) - Load test data
- show_urls() - Display URL patterns
- show_queries() - Show SQL queries
- shell_plus() - Enhanced shell (if django-extensions installed)

Common models imported:
- User
- Obligation
- AuditLog

Type help() for interactive help
""")

# Clean up namespace
del Path, django, logging, json, datetime
